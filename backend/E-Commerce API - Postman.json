{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "name": "E-Commerce API",
    "description": "IMPORTANTE: ejecutar 'Login Admin' primero para que el token se guarde automaticamente en {{auth_token}}. Todos los requests heredan el Bearer token de la coleccion.",
